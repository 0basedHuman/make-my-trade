# Copy this file to .env and fill in your own values.
# Never commit .env — it contains real credentials.

# ── Market data — Alpaca ─────────────────────────────────────
# Live keys (not used in paper-trading mode, but required by config loader)
ALPACA_API_KEY=your_alpaca_live_api_key
ALPACA_SECRET_KEY=your_alpaca_live_secret_key

# Paper trading keys (used for all order execution)
# Get these from https://app.alpaca.markets → Paper Account → API Keys
ALPACA_PAPER_API_KEY=your_alpaca_paper_api_key
ALPACA_PAPER_SECRET_KEY=your_alpaca_paper_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ── News + sentiment — Finnhub ───────────────────────────────
# Free tier works for POC. Get key at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key

# ── Macro data — FRED ────────────────────────────────────────
# Free. Get key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# ── Claude API — Anthropic ───────────────────────────────────
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Token budget (these defaults work for the POC watchlist size)
CLAUDE_INPUT_TOKEN_BUDGET=1200
CLAUDE_MAX_OUTPUT_TOKENS=8000

# ── Watchlist ────────────────────────────────────────────────
# Comma-separated tickers. SPY/TQQQ skip the fundamentals gate automatically.
WATCHLIST=AAPL,COIN,NFLX,HOOD,CRWV,GOOGL,MSFT,TSLA,META,AMZN,HD,AMD,SPY,TQQQ,SMCI,SNOW,BA,PANW,CRWD,LMT,RTX,XOM,OXY,LLY,FCX

# ── Trading mode ─────────────────────────────────────────────
# Paper trading runs automatically — no human approval needed.
# Live trading is disabled until explicitly enabled.
PAPER_TRADE_ENABLED=true
LIVE_TRADE_ENABLED=false

# ── Infrastructure ───────────────────────────────────────────
# Run `docker-compose up -d` to start Postgres, Redis, and Temporal locally.
DB_URL=postgres://makemytrade:makemytrade_secret@localhost:5432/makemytrade?sslmode=disable
REDIS_URL=redis://localhost:6379/0
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
PORT=8080
ENV=development
