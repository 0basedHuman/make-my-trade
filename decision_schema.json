{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OptionsPaperTradeDecision",
  "type": "object",
  "required": [
    "scan_time_pt",
    "market_regime",
    "daily_summary",
    "candidates",
    "open_positions_review"
  ],
  "properties": {
    "scan_time_pt": { "type": "string" },
    "market_regime": {
      "type": "object",
      "required": ["label", "confidence", "reason"],
      "properties": {
        "label": { "enum": ["bullish", "bearish", "mixed", "choppy_high_risk"] },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "daily_summary": {
      "type": "object",
      "required": ["action_bias", "notes"],
      "properties": {
        "action_bias": { "enum": ["long_calls", "long_puts", "selective_both", "no_trade_bias"] },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ticker",
          "setup_family",
          "direction",
          "status",
          "options_status",
          "score",
          "regime_fit",
          "reason_codes",
          "thesis",
          "levels",
          "targets",
          "contract_selection",
          "entry_trigger",
          "risk_plan",
          "hold_overnight_rule",
          "daily_review_rule",
          "final_decision"
        ],
        "properties": {
          "ticker": { "type": "string" },
          "setup_family": {
            "type": "string",
            "enum": [
              "bullish_continuation",
              "bullish_momentum_breakout",
              "bearish_continuation",
              "bearish_momentum_breakdown",
              "none"
            ]
          },
          "direction": { "enum": ["call", "put", "none"] },
          "status": {
            "enum": [
              "rejected",
              "structural_candidate",
              "entry_ready",
              "confirmed",
              "watch_only"
            ]
          },
          "options_status": {
            "enum": [
              "options_not_allowed",
              "options_ready",
              "options_confirmed"
            ]
          },
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "regime_fit": { "type": "integer", "minimum": 0, "maximum": 100 },
          "reason_codes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "thesis": {
            "type": "object",
            "required": [
              "trend_structure",
              "catalyst_sentiment",
              "volume_participation",
              "technical_confirmation",
              "fundamental_context"
            ],
            "properties": {
              "trend_structure": { "type": "string" },
              "catalyst_sentiment": { "type": "string" },
              "volume_participation": { "type": "string" },
              "technical_confirmation": { "type": "string" },
              "fundamental_context": { "type": "string" }
            },
            "additionalProperties": false
          },
          "levels": {
            "type": "object",
            "required": [
              "premarket_high",
              "premarket_low",
              "prior_day_high",
              "prior_day_low",
              "vwap",
              "key_support",
              "key_resistance"
            ],
            "properties": {
              "premarket_high": { "type": ["number", "null"] },
              "premarket_low": { "type": ["number", "null"] },
              "prior_day_high": { "type": ["number", "null"] },
              "prior_day_low": { "type": ["number", "null"] },
              "vwap": { "type": ["number", "null"] },
              "key_support": { "type": "array", "items": { "type": "number" } },
              "key_resistance": { "type": "array", "items": { "type": "number" } }
            },
            "additionalProperties": false
          },
          "targets": {
            "type": "object",
            "required": [
              "conservative_underlying_target",
              "base_underlying_target",
              "stretch_underlying_target",
              "hold_window_days"
            ],
            "properties": {
              "conservative_underlying_target": { "type": ["number", "null"] },
              "base_underlying_target": { "type": ["number", "null"] },
              "stretch_underlying_target": { "type": ["number", "null"] },
              "hold_window_days": {
                "type": "object",
                "required": ["min", "base", "max"],
                "properties": {
                  "min": { "type": "integer" },
                  "base": { "type": "integer" },
                  "max": { "type": "integer" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "contract_selection": {
            "type": "object",
            "required": [
              "selected",
              "type",
              "expiration_dte",
              "target_delta_range",
              "strike_logic",
              "liquidity_check",
              "reason"
            ],
            "properties": {
              "selected": { "type": "boolean" },
              "type": { "enum": ["call", "put", "none"] },
              "expiration_dte": { "type": ["integer", "null"] },
              "target_delta_range": { "type": ["string", "null"] },
              "strike_logic": { "type": "string" },
              "liquidity_check": { "enum": ["pass", "fail", "borderline"] },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          },
          "entry_trigger": {
            "type": "object",
            "required": ["type", "underlying_trigger_price", "explanation", "invalidation"],
            "properties": {
              "type": { "enum": ["breakout_stop_limit", "breakdown_stop_limit", "pullback_limit", "rejection_limit", "none"] },
              "underlying_trigger_price": { "type": ["number", "null"] },
              "explanation": { "type": "string" },
              "invalidation": { "type": "string" }
            },
            "additionalProperties": false
          },
          "risk_plan": {
            "type": "object",
            "required": [
              "initial_stop_loss_pct",
              "first_profit_zone_pct",
              "breakeven_shift_trigger_pct",
              "trail_activation_pct",
              "trailing_method",
              "trailing_value"
            ],
            "properties": {
              "initial_stop_loss_pct": { "type": "number" },
              "first_profit_zone_pct": { "type": "string" },
              "breakeven_shift_trigger_pct": { "type": "number" },
              "trail_activation_pct": { "type": "string" },
              "trailing_method": { "enum": ["premium_pct", "structure_based", "none"] },
              "trailing_value": { "type": "string" }
            },
            "additionalProperties": false
          },
          "hold_overnight_rule": {
            "type": "object",
            "required": ["allowed", "reason"],
            "properties": {
              "allowed": { "type": "boolean" },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          },
          "daily_review_rule": {
            "type": "object",
            "required": ["next_action_if_open", "reason"],
            "properties": {
              "next_action_if_open": { "enum": ["hold", "tighten_trail", "partial_profit", "exit_now", "exit_on_trigger"] },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          },
          "final_decision": { "enum": ["paper_trade_now", "place_trigger_only", "watchlist_only", "reject"] }
        },
        "additionalProperties": false
      }
    },
    "open_positions_review": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "option_type", "status", "reason"],
        "properties": {
          "ticker": { "type": "string" },
          "option_type": { "enum": ["call", "put"] },
          "status": { "enum": ["hold", "tighten_trail", "partial_profit", "exit_now", "exit_on_trigger"] },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
