#!/usr/bin/env bash
# version — lightweight local snapshot tool for make-my-trade
#
# WHAT: Save, list, and restore named snapshots of the entire codebase.
#       Each snapshot is a full copy of all source files stored in ~/.mmt-versions/.
#       Nothing is pushed anywhere — fully local and offline.
#
# COMMANDS:
#   ./version save  <tag> "<what is working now>"
#   ./version list
#   ./version goto  <tag>
#   ./version diff  <tag>
#   ./version show  <tag>
#   ./version delete <tag>
#
# EXAMPLES:
#   ./version save  v0.1 "baseline: full pipeline, alpaca orders live"
#   ./version save  v0.2 "added prompt caching, 20% cheaper"
#   ./version list
#   ./version goto  v0.1
#   ./version diff  v0.1

set -euo pipefail

# ── Config ────────────────────────────────────────────────────────────────────
SNAPSHOTS_DIR="$HOME/.mmt-versions"
REGISTRY="$SNAPSHOTS_DIR/registry.json"
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Files/dirs to exclude from snapshots (secrets, binaries, noise)
EXCLUDES=(
  ".env"
  "bin/"
  "logs/"
  ".claude/"
  "*.log"
  "*.pid"
  "tmp/"
  "*.tmp"
  ".DS_Store"
)

# ── Helpers ───────────────────────────────────────────────────────────────────
red()    { echo -e "\033[31m$*\033[0m"; }
green()  { echo -e "\033[32m$*\033[0m"; }
yellow() { echo -e "\033[33m$*\033[0m"; }
bold()   { echo -e "\033[1m$*\033[0m"; }

require_jq() {
  if ! command -v jq &>/dev/null; then
    red "error: jq is required. Install with: brew install jq"
    exit 1
  fi
}

ensure_registry() {
  mkdir -p "$SNAPSHOTS_DIR"
  if [[ ! -f "$REGISTRY" ]]; then
    echo '{"versions":[]}' > "$REGISTRY"
  fi
}

tag_exists() {
  local tag="$1"
  jq -e --arg t "$tag" '.versions[] | select(.tag == $t)' "$REGISTRY" &>/dev/null
}

build_excludes_args() {
  local args=()
  for ex in "${EXCLUDES[@]}"; do
    args+=("--exclude=$ex")
  done
  echo "${args[@]}"
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_save() {
  require_jq
  ensure_registry

  local tag="${1:-}"
  local description="${2:-}"

  if [[ -z "$tag" ]]; then
    red "usage: ./version save <tag> \"<what is working now>\""
    echo "  example: ./version save v0.2 \"alpaca orders live, position review working\""
    exit 1
  fi

  if tag_exists "$tag"; then
    yellow "warning: tag '$tag' already exists — overwriting"
    cmd_delete "$tag" --quiet
  fi

  local snap_dir="$SNAPSHOTS_DIR/$tag"
  mkdir -p "$snap_dir"

  echo "Saving snapshot '$tag'..."

  # Build rsync exclude args
  local exclude_args
  exclude_args=$(build_excludes_args)

  # shellcheck disable=SC2086
  rsync -a --delete $exclude_args "$PROJECT_DIR/" "$snap_dir/"

  # Record in registry
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local new_entry
  new_entry=$(jq -n \
    --arg tag "$tag" \
    --arg desc "$description" \
    --arg ts "$timestamp" \
    --arg dir "$snap_dir" \
    '{tag: $tag, description: $desc, saved_at: $ts, path: $dir}')

  local tmp
  tmp=$(mktemp)
  jq --argjson entry "$new_entry" '.versions += [$entry]' "$REGISTRY" > "$tmp"
  mv "$tmp" "$REGISTRY"

  green "✓ Saved '$tag'"
  if [[ -n "$description" ]]; then
    echo "  $description"
  fi
  echo "  Location: $snap_dir"
}

cmd_list() {
  require_jq
  ensure_registry

  local count
  count=$(jq '.versions | length' "$REGISTRY")

  if [[ "$count" -eq 0 ]]; then
    yellow "No snapshots saved yet."
    echo "  Run: ./version save v0.1 \"description of what works\""
    return
  fi

  bold "Saved versions ($count):"
  echo ""

  # Print table
  jq -r '.versions[] | "  \(.tag)\t\(.saved_at)\t\(.description)"' "$REGISTRY" | \
    while IFS=$'\t' read -r tag ts desc; do
      # Format date as local time
      local_ts=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "$ts" "+%b %d %H:%M" 2>/dev/null || echo "$ts")
      printf "  %-25s  %-14s  %s\n" "$(bold "$tag")" "$local_ts" "$desc"
    done
  echo ""
}

cmd_goto() {
  require_jq
  ensure_registry

  local tag="${1:-}"
  if [[ -z "$tag" ]]; then
    red "usage: ./version goto <tag>"
    cmd_list
    exit 1
  fi

  if ! tag_exists "$tag"; then
    red "error: version '$tag' not found"
    cmd_list
    exit 1
  fi

  local snap_dir
  snap_dir=$(jq -r --arg t "$tag" '.versions[] | select(.tag == $t) | .path' "$REGISTRY")

  if [[ ! -d "$snap_dir" ]]; then
    red "error: snapshot directory missing: $snap_dir"
    exit 1
  fi

  echo ""
  yellow "WARNING: This will overwrite your current working files."
  yellow "Any unsaved changes will be lost."
  echo ""
  read -r -p "Restore '$tag'? [y/N] " confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Cancelled."
    exit 0
  fi

  echo "Restoring '$tag'..."

  local exclude_args
  exclude_args=$(build_excludes_args)

  # shellcheck disable=SC2086
  rsync -a --delete $exclude_args "$snap_dir/" "$PROJECT_DIR/"

  green "✓ Restored '$tag'"
  local desc
  desc=$(jq -r --arg t "$tag" '.versions[] | select(.tag == $t) | .description' "$REGISTRY")
  if [[ -n "$desc" ]]; then
    echo "  $desc"
  fi
  echo ""
  echo "Rebuild the binary:"
  echo "  go build -o bin/server ./cmd/server && go build -o bin/worker ./cmd/worker"
}

cmd_diff() {
  require_jq
  ensure_registry

  local tag="${1:-}"
  if [[ -z "$tag" ]]; then
    red "usage: ./version diff <tag>"
    exit 1
  fi

  if ! tag_exists "$tag"; then
    red "error: version '$tag' not found"
    exit 1
  fi

  local snap_dir
  snap_dir=$(jq -r --arg t "$tag" '.versions[] | select(.tag == $t) | .path' "$REGISTRY")

  echo "Changes since '$tag':"
  echo ""

  # Use diff to compare, excluding binary and noise files
  diff -rq \
    --exclude=".env" \
    --exclude="*.log" \
    --exclude="*.pid" \
    --exclude=".DS_Store" \
    --exclude="*.test" \
    "$snap_dir" "$PROJECT_DIR" 2>/dev/null || true
}

cmd_show() {
  require_jq
  ensure_registry

  local tag="${1:-}"
  if [[ -z "$tag" ]]; then
    red "usage: ./version show <tag>"
    exit 1
  fi

  if ! tag_exists "$tag"; then
    red "error: version '$tag' not found"
    exit 1
  fi

  jq --arg t "$tag" '.versions[] | select(.tag == $t)' "$REGISTRY"
}

cmd_delete() {
  require_jq
  ensure_registry

  local tag="${1:-}"
  local quiet="${2:-}"

  if [[ -z "$tag" ]]; then
    red "usage: ./version delete <tag>"
    exit 1
  fi

  if ! tag_exists "$tag"; then
    red "error: version '$tag' not found"
    exit 1
  fi

  local snap_dir
  snap_dir=$(jq -r --arg t "$tag" '.versions[] | select(.tag == $t) | .path' "$REGISTRY")

  rm -rf "$snap_dir"

  local tmp
  tmp=$(mktemp)
  jq --arg t "$tag" '.versions = [.versions[] | select(.tag != $t)]' "$REGISTRY" > "$tmp"
  mv "$tmp" "$REGISTRY"

  if [[ "$quiet" != "--quiet" ]]; then
    green "✓ Deleted '$tag'"
  fi
}

cmd_help() {
  bold "version — local snapshot tool for make-my-trade"
  echo ""
  echo "Usage:"
  echo "  ./version save   <tag> \"<what is working now>\""
  echo "  ./version list"
  echo "  ./version goto   <tag>"
  echo "  ./version diff   <tag>"
  echo "  ./version show   <tag>"
  echo "  ./version delete <tag>"
  echo ""
  echo "Examples:"
  echo "  ./version save  v0.1 \"baseline: full pipeline, alpaca orders live\""
  echo "  ./version save  v0.2 \"added prompt caching, 20% cheaper\""
  echo "  ./version list"
  echo "  ./version goto  v0.1"
  echo "  ./version diff  v0.1"
  echo ""
  echo "Snapshots are stored in: $SNAPSHOTS_DIR"
  echo ".env and bin/ are never included in snapshots."
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  save)    cmd_save "$@" ;;
  list)    cmd_list ;;
  goto)    cmd_goto "$@" ;;
  diff)    cmd_diff "$@" ;;
  show)    cmd_show "$@" ;;
  delete)  cmd_delete "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    red "unknown command: $COMMAND"
    cmd_help
    exit 1
    ;;
esac
